<navigation-bar title="消息" back="{{false}}" color="black" background="#e3e3e5"></navigation-bar>

<scroll-view class="scrollarea" scroll-y enhanced enable-flex show-scrollbar="false">
  <view class="page">
    <view class="header">
      <view class="header-title">
        消息
        <text wx:if="{{unreadTotal > 0}}" class="unread-count-pill">{{unreadTotalText}}</text>
      </view>
      <view class="header-icon"></view>
    </view>

    <view class="search-bar">
      <text class="search-icon"></text>
      <text>搜索会话...</text>
    </view>

    <view wx:if="{{!currentUser}}" class="chat-list">
      <view class="state-card">
        <view class="state-title">请先登录查看聊天信息</view>
        <button class="auth-btn" bindtap="goAuth">去登录</button>
      </view>
    </view>

    <view wx:elif="{{sessions.length === 0}}" class="chat-list">
      <view class="state-card">
        <view class="state-title">暂无会话</view>
        <view class="state-desc">去搜索页申请借用后会出现在这里。</view>
      </view>
    </view>

    <view wx:else class="chat-list">
      <view
        wx:for="{{sessions}}"
        wx:key="id"
        class="chat-row {{item.unreadCount > 0 ? 'unread' : ''}}"
        data-id="{{item.id}}"
        bindtap="openChat"
      >
        <view class="avatar">{{item.peerInitial}}</view>

        <view class="chat-content">
          <view class="chat-header">
            <view class="chat-name">{{item.peerName}}</view>
            <view class="chat-time">{{item.relativeTime}}</view>
          </view>
          <view class="chat-preview">
            <view wx:if="{{item.unreadCount > 0}}" class="badge-container">
              <view class="row-badge">{{item.unreadText}}</view>
            </view>
            <text>{{item.previewText}}</text>
          </view>
        </view>

        <view class="item-thumbnail">{{item.itemTitleShort}}</view>
      </view>
    </view>
  </view>
</scroll-view>
