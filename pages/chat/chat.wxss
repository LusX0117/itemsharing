page {
  height: 100vh;
  background: #e3e3e5;
  color: #1c1c1e;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chat-page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.header-section {
  padding: 20rpx 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.nav-bar {
  display: flex;
  justify-content: center;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #d9d9d9;
  color: #4b5563;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
}

.item-card-sticky {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.05);
}

.item-thumb {
  width: 78rpx;
  height: 78rpx;
  background: #ededed;
  border-radius: 12rpx;
  color: #6b7280;
  font-size: 20rpx;
  line-height: 1.2;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx;
  box-sizing: border-box;
}

.item-details {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.status-badge {
  display: inline-block;
  margin-top: 6rpx;
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.status-active {
  color: #34c759;
  background: #e8f5e9;
}

.status-pending {
  color: #f59e0b;
  background: #fef3c7;
}

.status-flagged {
  color: #ff3b30;
  background: #ffebee;
}

.status-action-btn {
  margin: 0;
  margin-left: 8rpx;
  min-width: 132rpx;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 14rpx !important;
  border-radius: 999rpx !important;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
  border: 0 !important;
}

.status-action-btn.action-approve {
  background: #1c1c1e !important;
  color: #ffffff !important;
}

.status-action-btn.action-return {
  background: #2563eb !important;
  color: #ffffff !important;
}

.status-action-btn.action-confirm {
  background: #16a34a !important;
  color: #ffffff !important;
}

.status-action-btn::after {
  border: 0;
}

.stepper-container {
  margin-bottom: 12rpx;
  padding: 0 24rpx;
  display: flex;
  justify-content: space-between;
  position: relative;
}

.stepper-line {
  position: absolute;
  top: 18rpx;
  left: 50rpx;
  right: 50rpx;
  height: 2rpx;
  background: #d1d1d6;
  z-index: 1;
}

.step {
  width: 25%;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.step-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 3rpx solid #d1d1d6;
}

.step.active .step-dot {
  background: #1c1c1e;
  border-color: #1c1c1e;
}

.step.completed .step-dot {
  background: #34c759;
  border-color: #34c759;
}

.step-label {
  font-size: 18rpx;
  font-weight: 500;
  color: #8e8e93;
}

.step.active .step-label {
  color: #1c1c1e;
  font-weight: 600;
}

.chat-area {
  flex: 1;
  min-height: 0;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.message-row {
  width: 100%;
  display: flex;
  margin-bottom: 12rpx;
}

.message-row.other {
  justify-content: flex-start;
}

.message-row.mine {
  justify-content: flex-end;
}

.message-row.system {
  justify-content: center;
}

.message {
  display: inline-block;
  width: auto;
  max-width: 80%;
  padding: 14rpx 18rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  line-height: 1.45;
  box-sizing: border-box;
}

.message.received {
  background: #ffffff;
  color: #1c1c1e;
  border-bottom-left-radius: 8rpx;
}

.message.sent {
  background: #eceff3;
  color: #1c1c1e;
  border-bottom-right-radius: 8rpx;
}

.message.system {
  max-width: 80%;
  background: #fff7ed;
  color: #9a3412;
  border: 1rpx solid #fed7aa;
  border-radius: 12rpx;
}

.message-text {
  word-break: break-word;
}

.timestamp {
  margin-top: 6rpx;
  display: block;
  font-size: 18rpx;
  color: #8e8e93;
}

.message.sent .timestamp {
  color: #8e8e93;
  text-align: right;
}

.message.system .timestamp {
  color: #c2410c;
  text-align: right;
}

.input-bar-container {
  padding: 12rpx 24rpx calc(22rpx + env(safe-area-inset-bottom));
  background: #e3e3e5;
}

.input-wrapper {
  background: #ffffff;
  border-radius: 999rpx;
  padding: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.05);
}

.attach-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #e3e3e5;
  color: #8e8e93;
  font-size: 32rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 10rpx;
}

.send-btn {
  width: 56rpx !important;
  height: 56rpx !important;
  min-width: 56rpx !important;
  max-width: 56rpx !important;
  min-height: 56rpx !important;
  max-height: 56rpx !important;
  flex: 0 0 56rpx;
  border-radius: 999rpx !important;
  background: #1c1c1e !important;
  color: #ffffff !important;
  padding: 0 !important;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-sizing: border-box;
  flex-shrink: 0;
}

.send-btn::after {
  border: 0;
}

.empty {
  color: #8e8e93;
  font-size: 22rpx;
  text-align: center;
  margin-top: 12rpx;
}

.missing-page {
  padding: 48rpx 24rpx;
  color: #8e8e93;
  text-align: center;
}
