<navigation-bar title="我的" back="{{false}}" color="black" background="#e3e3e5"></navigation-bar>

<scroll-view class="scrollarea" scroll-y enhanced enable-flex show-scrollbar="false">
  <view class="page-wrap">
    <view class="header-row">
      <view class="header-title">My—
Profile</view>
      <view class="close-btn" bindtap="goHome">✕</view>
    </view>

    <view class="profile-card">
      <view class="user-info">
        <view class="avatar">{{avatarText}}</view>
        <view class="user-meta">
          <view class="name-row">
            <view class="user-name">{{currentUser ? currentUser.nickname : 'Guest User'}}</view>
            <view wx:if="{{isAdmin}}" class="role-tag">Admin</view>
          </view>
          <view class="user-id">{{currentUser ? ('Phone: ' + currentUser.phone) : '登录后可查看与管理帖子'}}</view>
        </view>
      </view>

      <view class="stats-row">
        <view class="stat-item">
          <view class="stat-value">{{stats.myPostCount}}</view>
          <view class="stat-label">Items Offered</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{stats.sessionCount}}</view>
          <view class="stat-label">Chats</view>
        </view>
        <view class="stat-item">
          <view class="stat-value">{{stats.itemCount}}</view>
          <view class="stat-label">Platform Posts</view>
        </view>
      </view>
    </view>

    <view class="menu-card" wx:if="{{currentUser}}">
      <view class="menu-row" bindtap="goPostManage">
        <view class="menu-label">My Listings</view>
        <view class="menu-arrow">→</view>
      </view>
      <view class="menu-row" bindtap="goMessages">
        <view class="menu-label">Borrow History</view>
        <view class="menu-arrow">→</view>
      </view>
    </view>

    <view class="menu-card" wx:else>
      <view class="menu-row" bindtap="goAuth">
        <view class="menu-label">Log In / Register</view>
        <view class="menu-arrow">→</view>
      </view>
    </view>
  </view>
</scroll-view>

<view class="bottom-action" wx:if="{{currentUser}}">
  <button class="btn-logout" bindtap="logout">Log Out</button>
</view>

<view class="bottom-action" wx:else>
  <button class="btn-login" bindtap="goAuth">Log In / Register</button>
</view>
