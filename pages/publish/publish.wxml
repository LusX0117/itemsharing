<navigation-bar title="发布" back="{{false}}" color="black" background="#e3e3e5"></navigation-bar>

<scroll-view class="scrollarea" scroll-y enhanced enable-flex show-scrollbar="false">
  <view class="page">
    <view class="header-row">
      <view class="header-title">{{mode === 'lend' ? '发布出借' : '发布求借'}}</view>
      <view class="close-btn" bindtap="goHome">✕</view>
    </view>

    <view wx:if="{{!currentUser}}" class="auth-card">
      <view class="auth-title">请先登录后发布信息</view>
      <button class="auth-btn" bindtap="goAuth">去登录</button>
    </view>

    <view wx:else class="form-card">
      <view class="mode-switch">
        <view class="mode-tab {{mode === 'lend' ? 'active' : ''}}" data-mode="lend" bindtap="switchMode">出借发布</view>
        <view class="mode-tab {{mode === 'demand' ? 'active' : ''}}" data-mode="demand" bindtap="switchMode">求借发布</view>
      </view>

      <view wx:if="{{mode === 'lend'}}" class="form-panel">
        <view class="input-group">
          <view class="input-label">照片</view>
          <view class="photo-upload-grid">
            <view
              wx:for="{{photoSlotIndexes}}"
              wx:key="*this"
              class="photo-slot {{lendForm.photos[index] ? 'filled' : ''}}"
              data-index="{{index}}"
              bindtap="handlePhotoSlotTap"
            >
              <image wx:if="{{lendForm.photos[index]}}" class="photo-image" src="{{lendForm.photos[index]}}" mode="aspectFill" />
              <text wx:else class="plus-icon">＋</text>
              <view
                wx:if="{{lendForm.photos[index]}}"
                class="photo-remove"
                data-index="{{index}}"
                catchtap="removeLendPhoto"
              >
                ✕
              </view>
            </view>
          </view>
        </view>

        <view class="input-group">
          <view class="input-label">标题</view>
          <input class="form-input" placeholder="例如：无线电钻" value="{{lendForm.title}}" data-field="title" bindinput="handleLendInput" />
        </view>

        <view class="input-group">
          <view class="input-label">分类</view>
          <picker mode="selector" range="{{categoryOptions}}" bindchange="chooseLendCategory">
            <view class="form-picker">{{lendForm.category}}</view>
          </picker>
        </view>

        <view class="input-group two-col">
          <view class="col">
            <view class="input-label">日租金</view>
            <input class="form-input" type="digit" placeholder="0" value="{{lendForm.price}}" data-field="price" bindinput="handleLendInput" />
          </view>
          <view class="col">
            <view class="input-label">押金</view>
            <input class="form-input" type="digit" placeholder="0" value="{{lendForm.deposit}}" data-field="deposit" bindinput="handleLendInput" />
          </view>
        </view>

        <view class="input-group">
          <view class="input-label">交接地点</view>
          <input class="form-input" placeholder="例如：图书馆一楼" value="{{lendForm.location}}" data-field="location" bindinput="handleLendInput" />
        </view>

        <view class="input-group">
          <view class="input-label">描述</view>
          <textarea class="form-textarea" placeholder="品牌、成色、使用说明等" value="{{lendForm.description}}" data-field="description" bindinput="handleLendInput" />
        </view>
      </view>

      <view wx:else class="form-panel">
        <view class="input-group">
          <view class="input-label">标题</view>
          <input class="form-input" placeholder="例如：求借单反相机一天" value="{{demandForm.title}}" data-field="title" bindinput="handleDemandInput" />
        </view>

        <view class="input-group">
          <view class="input-label">分类</view>
          <picker mode="selector" range="{{categoryOptions}}" bindchange="chooseDemandCategory">
            <view class="form-picker">{{demandForm.category}}</view>
          </picker>
        </view>

        <view class="input-group two-col">
          <view class="col">
            <view class="input-label">预算</view>
            <input class="form-input" type="digit" placeholder="0" value="{{demandForm.budget}}" data-field="budget" bindinput="handleDemandInput" />
          </view>
          <view class="col">
            <view class="input-label">感谢方式</view>
            <input class="form-input" placeholder="可协商" value="{{demandForm.reward}}" data-field="reward" bindinput="handleDemandInput" />
          </view>
        </view>

        <view class="input-group">
          <view class="input-label">交接地点</view>
          <input class="form-input" placeholder="例如：宿舍区门口" value="{{demandForm.location}}" data-field="location" bindinput="handleDemandInput" />
        </view>

        <view class="input-group">
          <view class="input-label">描述</view>
          <textarea class="form-textarea" placeholder="补充时间、用途、要求等" value="{{demandForm.description}}" data-field="description" bindinput="handleDemandInput" />
        </view>
      </view>
    </view>
  </view>
</scroll-view>

<view wx:if="{{currentUser}}" class="bottom-action">
  <button class="btn-submit" bindtap="submitPublish">
    <text>{{mode === 'lend' ? '发布物品' : '发布求借'}}</text>
    <text class="btn-icon">→</text>
  </button>
</view>
