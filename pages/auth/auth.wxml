<navigation-bar title="账号中心" color="black" background="#e3e3e5"></navigation-bar>

<scroll-view class="scrollarea" scroll-y enhanced enable-flex show-scrollbar="false">
  <view class="page-wrap">
    <view class="header-row">
      <view class="header-title">Share—
Network</view>
      <view class="close-btn" bindtap="goBack">✕</view>
    </view>

    <view class="auth-tabs">
      <view class="tab-item {{mode === 'login' ? 'active' : ''}}" data-mode="login" bindtap="switchMode">Login</view>
      <view class="tab-item {{mode === 'register' ? 'active' : ''}}" data-mode="register" bindtap="switchMode">Register</view>
    </view>

    <view class="form-card">
      <view class="input-group">
        <view class="input-label">Phone Number</view>
        <input
          class="form-input"
          placeholder="11位手机号"
          type="number"
          maxlength="11"
          value="{{form.phone}}"
          data-field="phone"
          bindinput="handleInput"
        />
      </view>

      <view class="input-group">
        <view class="label-row">
          <view class="input-label">Password</view>
          <view wx:if="{{mode === 'login'}}" class="forgot-link" bindtap="forgotPassword">Forgot?</view>
        </view>
        <input
          class="form-input"
          placeholder="至少6位"
          password
          value="{{form.password}}"
          data-field="password"
          bindinput="handleInput"
        />
      </view>

      <view wx:if="{{mode === 'register'}}" class="input-group">
        <view class="input-label">Nickname</view>
        <input
          class="form-input"
          placeholder="请输入昵称"
          value="{{form.nickname}}"
          data-field="nickname"
          bindinput="handleInput"
        />
      </view>
    </view>
  </view>
</scroll-view>

<view class="bottom-action">
  <button class="btn-submit" bindtap="submit">{{mode === 'login' ? 'Join Network' : 'Create Account'}}</button>
</view>
