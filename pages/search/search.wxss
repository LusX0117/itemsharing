page {
  height: 100vh;
  background: #e3e3e5;
  color: #1c1c1e;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page-shell {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.sticky-header {
  flex: none;
  background: #e3e3e5;
  padding: 22rpx 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.page-title {
  font-size: 54rpx;
  line-height: 1.08;
  font-weight: 700;
  letter-spacing: -1rpx;
  color: #1c1c1e;
  padding: 0 8rpx;
}

.search-container {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.search-bar {
  flex: 1;
  min-width: 0;
  height: 86rpx;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.05);
}

.search-icon {
  font-size: 30rpx;
  color: #8e8e93;
  line-height: 1;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 86rpx;
  line-height: 86rpx;
  font-size: 26rpx;
  color: #1c1c1e;
}

.search-placeholder {
  color: #8e8e93;
}

.cancel-link {
  flex: none;
  padding: 6rpx 0;
  color: #1c1c1e;
  font-size: 26rpx;
  font-weight: 500;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  padding: 0 24rpx;
  height: 62rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #5d646f;
  font-size: 22rpx;
  font-weight: 500;
}

.filter-chip.active {
  background: #1c1c1e;
  color: #ffffff;
}

.auth-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.auth-text {
  flex: 1;
  min-width: 0;
  color: #666b74;
  font-size: 22rpx;
}

.auth-link {
  flex: none;
  color: #1c1c1e;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 0;
}

.results-scroll {
  flex: 1;
  min-height: 0;
}

.content-area {
  padding: 6rpx 24rpx calc(170rpx + env(safe-area-inset-bottom));
}

.results-count {
  font-size: 22rpx;
  font-weight: 500;
  color: #7b8089;
  margin: 4rpx 2rpx 14rpx;
}

.item-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
}

.item-image {
  width: 92rpx;
  height: 92rpx;
  border-radius: 18rpx;
  background: #eaedf1;
  color: #3f4652;
  font-size: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.item-image-inner {
  width: 100%;
  height: 100%;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1c1c1e;
  line-height: 1.32;
  word-break: break-all;
}

.item-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8e8e93;
}

.item-meta.available {
  color: #16a34a;
}

.item-price {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.borrow-btn {
  margin: 0;
  flex-shrink: 0;
  min-width: 110rpx;
  height: 58rpx !important;
  line-height: 58rpx !important;
  border-radius: 999rpx !important;
  background: #1c1c1e !important;
  color: #ffffff !important;
  font-size: 22rpx !important;
  padding: 0 22rpx !important;
}

.borrow-btn::after {
  border: 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 96rpx 28rpx;
}

.empty-illustration {
  width: 220rpx;
  height: 220rpx;
  border-radius: 110rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.empty-icon {
  font-size: 72rpx;
  opacity: 0.3;
}

.empty-title {
  margin-top: 22rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1c1c1e;
}

.empty-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7b8089;
}

.btn-clear {
  margin-top: 24rpx;
  border: 2rpx solid #1c1c1e;
  color: #1c1c1e;
  border-radius: 999rpx;
  padding: 14rpx 30rpx;
  font-size: 24rpx;
  font-weight: 600;
}
