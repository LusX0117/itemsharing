page {
  height: 100vh;
  background: #e3e3e5;
  color: #1c1c1e;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.scrollarea {
  flex: 1;
  min-height: 0;
}

.page-wrap {
  padding: 24rpx 24rpx calc(170rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 8rpx;
}

.header-title {
  white-space: pre-line;
  font-size: 54rpx;
  line-height: 1.08;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.bulk-toggle {
  font-size: 24rpx;
  font-weight: 600;
  color: #8e8e93;
  padding: 8rpx;
}

.tip-text {
  margin: 10rpx 8rpx 0;
  font-size: 22rpx;
  color: #8e8e93;
}

.tab-nav {
  margin: 16rpx 8rpx 0;
  display: flex;
  background: rgba(0, 0, 0, 0.05);
  padding: 6rpx;
  border-radius: 14rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  height: 66rpx;
  line-height: 66rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #8e8e93;
}

.tab-item.active {
  background: #ffffff;
  color: #1c1c1e;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.06);
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 14rpx;
}

.post-card {
  background: #ffffff;
  border-radius: 22rpx;
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.bulk-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 10rpx;
  border: 2rpx solid #d4d6db;
  background: transparent;
  margin-top: 4rpx;
  display: none;
  flex-shrink: 0;
}

.bulk-checkbox.checked {
  border-color: #1c1c1e;
  background: #1c1c1e;
}

.bulk-mode .bulk-checkbox {
  display: block;
}

.post-details {
  flex: 1;
  min-width: 0;
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.post-title {
  flex: 1;
  font-weight: 700;
  font-size: 30rpx;
  line-height: 1.35;
  color: #1c1c1e;
  word-break: break-all;
}

.status-badge {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

.status-active {
  background: #e8f5e9;
  color: #34c759;
}

.status-pending {
  background: #fff3e0;
  color: #ff9500;
}

.status-flagged {
  background: #ffebee;
  color: #ff3b30;
}

.post-meta {
  margin-top: 10rpx;
  display: flex;
  gap: 16rpx;
  font-size: 22rpx;
  color: #8e8e93;
}

.post-reason {
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #b45309;
}

.post-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #f2f2f7;
}

.action-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  background: #edf0f4;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1c1c1e;
  font-size: 26rpx;
}

.action-icon.danger {
  color: #dc2626;
}

.empty-card {
  margin-top: 14rpx;
  background: #ffffff;
  border-radius: 22rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  color: #8e8e93;
  font-size: 24rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(170rpx + env(safe-area-inset-bottom));
  padding: 0 24rpx;
  z-index: 20;
}

.bulk-actions-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx !important;
  background: #1c1c1e !important;
  color: #ffffff !important;
  font-size: 28rpx !important;
  font-weight: 600;
}

.bulk-actions-btn::after {
  border: 0;
}
