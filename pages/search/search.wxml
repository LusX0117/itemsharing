<navigation-bar title="搜索" back="{{false}}" color="black" background="#e3e3e5"></navigation-bar>

<view class="page-shell">
  <view class="sticky-header">
    <view class="search-container">
      <view class="search-bar">
        <text class="search-icon">⌕</text>
        <input
          class="search-input"
          placeholder="搜索物品/地点/关键词"
          placeholder-class="search-placeholder"
          value="{{keyword}}"
          bindinput="handleKeywordInput"
          confirm-type="search"
        />
      </view>
      <view class="cancel-link" bindtap="clearKeyword">取消</view>
    </view>

    <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="false">
      <view
        wx:for="{{categoryOptions}}"
        wx:key="*this"
        class="filter-chip {{activeCategory === item ? 'active' : ''}}"
        data-category="{{item}}"
        bindtap="chooseCategory"
      >
        {{item}}
      </view>
    </scroll-view>

    <view class="auth-row">
      <view class="auth-text" wx:if="{{currentUser}}">当前账号：{{currentUser.nickname}}</view>
      <view class="auth-text" wx:else>未登录，登录后可直接申请借用</view>
      <view wx:if="{{!currentUser}}" class="auth-link" bindtap="goAuth">去登录</view>
    </view>
  </view>

  <scroll-view class="results-scroll" scroll-y enhanced enable-flex show-scrollbar="false">
    <view class="content-area">
      <view wx:if="{{filteredItems.length > 0}}" class="results-count">已找到 {{filteredItems.length}} 条结果</view>

      <view wx:for="{{filteredItems}}" wx:key="id" class="item-card">
        <view class="item-image">
          <image wx:if="{{item.photos && item.photos.length}}" class="item-image-inner" src="{{item.photos[0]}}" mode="aspectFill" />
          <text wx:else>{{item.icon}}</text>
        </view>
        <view class="item-info">
          <view class="item-title">{{item.title}}</view>
          <view class="item-meta">{{item.category}} · {{item.location}}</view>
          <view class="item-meta available">{{item.status || '可借'}}</view>
          <view class="item-price">¥{{item.price}}/天 · 押金 ¥{{item.deposit}}</view>
        </view>
        <button class="borrow-btn" size="mini" data-id="{{item.id}}" bindtap="applyBorrow">借用</button>
      </view>

      <view wx:if="{{filteredItems.length === 0}}" class="empty-state">
        <view class="empty-illustration">
          <view class="empty-icon">📦</view>
        </view>
        <view class="empty-title">暂无匹配物品</view>
        <view class="empty-text">当前没有符合条件的结果，试试更换关键词或分类。</view>
        <view class="btn-clear" bindtap="clearFilters">清空筛选</view>
      </view>
    </view>
  </scroll-view>
</view>
