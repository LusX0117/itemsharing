page {
  height: 100vh;
  background: #e3e3e5;
  color: #1c1c1e;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.scrollarea {
  flex: 1;
  min-height: 0;
}

.page {
  padding: 24rpx 24rpx calc(320rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.header-title {
  white-space: pre-line;
  font-size: 54rpx;
  line-height: 1.08;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.close-btn {
  font-size: 44rpx;
  color: #8e8e93;
  line-height: 1;
  padding: 8rpx;
}

.auth-card {
  background: #ffffff;
  border-radius: 26rpx;
  padding: 34rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
  text-align: center;
}

.auth-title {
  font-size: 26rpx;
  color: #6b7280;
}

.auth-btn {
  margin-top: 20rpx;
  background: #1c1c1e !important;
  color: #ffffff !important;
}

.form-card {
  background: #ffffff;
  border-radius: 30rpx;
  padding: 28rpx 22rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.mode-switch {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.mode-tab {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #edf0f4;
  color: #626b77;
  font-size: 24rpx;
  font-weight: 600;
}

.mode-tab.active {
  background: #1c1c1e;
  color: #ffffff;
}

.form-panel {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.input-label {
  font-size: 22rpx;
  color: #8e8e93;
  padding-left: 4rpx;
}

.photo-upload-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-slot {
  position: relative;
  height: 188rpx;
  background: #edf0f4;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.photo-slot.filled {
  background: #dfe3e8;
}

.plus-icon {
  color: #8e8e93;
  font-size: 44rpx;
  font-weight: 300;
}

.photo-image {
  width: 100%;
  height: 100%;
}

.photo-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: rgba(17, 24, 39, 0.72);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 36rpx;
  text-align: center;
}

.form-input,
.form-picker,
.form-textarea {
  width: 100%;
  background: #edf0f4;
  border-radius: 16rpx;
  box-sizing: border-box;
  color: #1c1c1e;
  font-size: 26rpx;
}

.form-input,
.form-picker {
  min-height: 92rpx;
  line-height: 92rpx;
  padding: 0 22rpx;
}

.form-picker {
  position: relative;
  padding-right: 56rpx;
}

.form-picker::after {
  content: '▾';
  position: absolute;
  right: 22rpx;
  top: 50%;
  transform: translateY(-50%);
  color: #8e8e93;
  font-size: 24rpx;
}

.form-textarea {
  min-height: 176rpx;
  padding: 16rpx 18rpx;
}

.two-col {
  flex-direction: row;
  gap: 12rpx;
}

.col {
  flex: 1;
  min-width: 0;
}

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  padding: 0 24rpx;
  z-index: 20;
}

.btn-submit {
  width: 100%;
  height: 94rpx;
  border-radius: 999rpx !important;
  background: #1c1c1e !important;
  color: #ffffff !important;
  font-size: 30rpx !important;
  font-weight: 600;
  padding: 0 30rpx !important;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.15);
}

.btn-submit::after {
  border: 0;
}

.btn-icon {
  font-size: 34rpx;
  line-height: 1;
}
