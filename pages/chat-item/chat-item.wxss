page {
  height: 100vh;
  background: #e3e3e5;
  color: #1c1c1e;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.detail-page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.content-scroll {
  flex: 1;
  min-height: 0;
}

.content-wrap {
  padding: 22rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.item-title {
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #1c1c1e;
  word-break: break-word;
}

.item-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #4b5563;
  white-space: pre-wrap;
  word-break: break-word;
}

.image-wrap {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.item-image {
  width: 100%;
  border-radius: 16rpx;
  background: #d7d9dd;
  display: block;
}

.image-empty {
  width: 100%;
  height: 260rpx;
  border-radius: 16rpx;
  background: #f1f3f6;
  color: #8e8e93;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-fab-wrap {
  position: fixed;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
}

.action-fab {
  margin: 0;
  min-width: 188rpx;
  height: 78rpx;
  padding: 0 24rpx !important;
  border-radius: 999rpx !important;
  background: #1c1c1e !important;
  color: #ffffff !important;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 78rpx;
  box-shadow: 0 14rpx 26rpx rgba(0, 0, 0, 0.18);
}

.action-fab::after {
  border: 0;
}

.missing-page {
  padding: 48rpx 24rpx;
  color: #8e8e93;
  text-align: center;
}
