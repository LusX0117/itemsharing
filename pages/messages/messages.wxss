page {
  height: 100vh;
  background: #e3e3e5;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.scrollarea {
  flex: 1;
  min-height: 0;
}

.page {
  padding: 24rpx 24rpx calc(170rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-end;
  padding: 0 8rpx;
}

.header-title {
  font-size: 54rpx;
  font-weight: 600;
  line-height: 1.1;
  letter-spacing: -1rpx;
  color: #1c1c1e;
}

.unread-count-pill {
  margin-left: 12rpx;
  display: inline-block;
  transform: translateY(-8rpx);
  background: #1c1c1e;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.header-icon {
  font-size: 34rpx;
  color: #1c1c1e;
  padding: 4rpx 8rpx;
}

.search-bar {
  margin-top: 18rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #8e8e93;
  font-size: 26rpx;
}

.search-icon {
  font-size: 24rpx;
}

.chat-list {
  margin-top: 18rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.chat-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-bottom: 1rpx solid #f2f2f7;
  position: relative;
}

.chat-row:last-child {
  border-bottom: 0;
}

.chat-row.unread::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  bottom: 20%;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
  background: #1c1c1e;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #ececef;
  color: #4b5563;
  font-weight: 700;
  font-size: 30rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chat-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 12rpx;
}

.chat-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1c1c1e;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.unread .chat-name {
  font-weight: 700;
}

.chat-time {
  font-size: 22rpx;
  color: #8e8e93;
  flex-shrink: 0;
}

.chat-preview {
  margin-top: 2rpx;
  font-size: 25rpx;
  color: #8e8e93;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.unread .chat-preview {
  color: #1c1c1e;
  font-weight: 500;
}

.badge-container {
  display: flex;
  align-items: center;
}

.row-badge {
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #1c1c1e;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 20rpx;
  font-weight: 700;
}

.item-thumbnail {
  width: 82rpx;
  height: 82rpx;
  border-radius: 12rpx;
  background: #ececef;
  color: #8e8e93;
  font-size: 18rpx;
  line-height: 1.2;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 6rpx;
}

.state-card {
  padding: 48rpx 24rpx;
  text-align: center;
}

.state-title {
  font-size: 28rpx;
  color: #1c1c1e;
}

.state-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8e8e93;
}

.auth-btn {
  margin-top: 16rpx;
  background: #1c1c1e !important;
  color: #ffffff !important;
}

.auth-btn::after {
  border: 0;
}
