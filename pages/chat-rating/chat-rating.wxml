<navigation-bar title="归还评价" color="black" background="#e3e3e5"></navigation-bar>

<view wx:if="{{loading}}" class="missing-page">评价信息加载中...</view>

<view wx:elif="{{session}}" class="rating-page">
  <scroll-view class="content-scroll" scroll-y enhanced enable-flex show-scrollbar="false">
    <view class="content-wrap">
      <view class="header-row">
        <view class="header-title-wrap">
          <view class="header-title">归还</view>
          <view class="header-title">评价</view>
        </view>
        <view class="close-btn" bindtap="goBack">✕</view>
      </view>

      <view class="item-summary-card">
        <view class="item-thumb">{{session.itemTitleShort}}</view>
        <view class="item-info">
          <view class="item-name">{{session.itemTitle}}</view>
          <view class="status-badge {{session.statusClassName}}">
            <view class="status-dot"></view>
            <text>{{session.statusText}}</text>
          </view>
        </view>
      </view>

      <view class="review-card">
        <view class="input-group">
          <view class="input-label center">本次借用体验如何？</view>
          <view class="rating-container">
            <text
              wx:for="{{starOptions}}"
              wx:key="*this"
              class="star-btn {{ratingScore >= item ? 'active' : ''}}"
              data-score="{{item}}"
              bindtap="selectScore"
            >★</text>
          </view>
          <view wx:if="{{!session.canRate}}" class="readonly-tip">你已提交过评价，当前为只读状态</view>
        </view>

        <view class="input-group">
          <view class="input-label">评价内容</view>
          <textarea
            class="form-textarea"
            placeholder="写下你对本次借用的评价..."
            value="{{reviewText}}"
            maxlength="300"
            disabled="{{!session.canRate}}"
            bindinput="handleReviewInput"
          ></textarea>
          <view class="credit-tip">评价对象：{{session.targetName}}（信用 {{session.targetCreditText}}）</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-action">
    <button class="btn-submit {{!session.canRate ? 'disabled' : ''}}" disabled="{{!session.canRate}}" bindtap="submitRating">
      <text>{{session.submitButtonText}}</text>
      <text>→</text>
    </button>
  </view>
</view>

<view wx:else class="missing-page">未找到借用会话</view>
