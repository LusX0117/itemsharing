page {
  height: 100vh;
  background: #e3e3e5;
  color: #1c1c1e;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.scrollarea {
  flex: 1;
  min-height: 0;
}

.page-wrap {
  padding: 28rpx 24rpx calc(170rpx + env(safe-area-inset-bottom));
}

.hero-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.hero-title {
  font-size: 56rpx;
  line-height: 1.08;
  letter-spacing: -1rpx;
  font-weight: 700;
  white-space: pre-line;
}

.profile-trigger {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #d1d1d6;
  color: #1c1c1e;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.tab-switch {
  display: flex;
  gap: 46rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
  padding: 0 4rpx 12rpx;
}

.tab-item {
  position: relative;
  font-size: 28rpx;
  font-weight: 600;
  color: #8e8e93;
  padding-bottom: 8rpx;
}

.tab-item.active {
  color: #1c1c1e;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: -13rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #1c1c1e;
}

.feed-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.feed-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  background: #ffffff;
  border-radius: 26rpx;
  padding: 22rpx;
  padding-right: 196rpx;
  min-height: 168rpx;
  box-shadow: 0 10rpx 26rpx rgba(0, 0, 0, 0.04);
}

.card-thumb {
  width: 92rpx;
  height: 92rpx;
  border-radius: 18rpx;
  background: #e5e5ea;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.card-thumb-image {
  width: 100%;
  height: 100%;
}

.card-main {
  flex: 1;
  min-width: 0;
}

.card-category {
  font-size: 20rpx;
  line-height: 1.3;
  letter-spacing: 1rpx;
  color: #8e8e93;
}

.card-title {
  margin-top: 6rpx;
  font-size: 32rpx;
  line-height: 1.28;
  color: #1c1c1e;
  font-weight: 700;
  word-break: break-all;
}

.card-meta {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #6b7280;
}

.card-price {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8e8e93;
}

.card-action {
  position: absolute;
  right: 22rpx;
  bottom: 22rpx;
  padding: 0 20rpx !important;
  line-height: 56rpx !important;
  height: 56rpx !important;
  border-radius: 999rpx !important;
  background: #111111 !important;
  color: #ffffff !important;
  font-size: 22rpx !important;
  border: 0 !important;
}

.card-action.demand {
  background: #0f766e !important;
}

.card-action::after {
  border: 0;
}

.empty-card {
  border-radius: 24rpx;
  background: #ffffff;
  color: #8e8e93;
  text-align: center;
  padding: 50rpx 24rpx;
  font-size: 26rpx;
}

.fab {
  position: fixed;
  right: 26rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 98rpx;
  height: 98rpx;
  border-radius: 49rpx;
  background: #1c1c1e;
  color: #ffffff;
  font-size: 54rpx;
  line-height: 98rpx;
  text-align: center;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.2);
}
