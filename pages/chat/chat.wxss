page {
  height: 100vh;
  background: #e3e3e5;
  color: #1c1c1e;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chat-page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.header-section {
  padding: 20rpx 24rpx 14rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #d9d9d9;
  color: #4b5563;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-name {
  font-weight: 600;
  font-size: 28rpx;
}

.back-btn {
  font-size: 34rpx;
  font-weight: 600;
  color: #1c1c1e;
  padding: 4rpx 8rpx;
}

.nav-placeholder {
  width: 50rpx;
}

.item-card-sticky {
  background: #ffffff;
  border-radius: 18rpx;
  padding: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.05);
}

.item-thumb {
  width: 72rpx;
  height: 72rpx;
  background: #ededed;
  border-radius: 12rpx;
  color: #6b7280;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.2;
  padding: 6rpx;
}

.item-details {
  flex: 1;
  min-width: 0;
}

.item-title {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.status-badge {
  display: inline-block;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  margin-top: 6rpx;
}

.status-active {
  background: #e8f5e9;
  color: #34c759;
}

.status-pending {
  background: #fff3e0;
  color: #ff9500;
}

.status-flagged {
  background: #ffebee;
  color: #ff3b30;
}

.entry-row {
  display: flex;
  gap: 10rpx;
}

.entry-btn {
  margin: 0;
  flex: 1;
  background: #edf0f4 !important;
  color: #1c1c1e !important;
}

.entry-btn::after {
  border: 0;
}

.chat-card {
  flex: 1;
  min-height: 0;
  margin: 0 24rpx 12rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 16rpx;
}

.chat-area {
  height: 100%;
}

.message {
  max-width: 82%;
  padding: 14rpx 18rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
  line-height: 1.45;
  margin-bottom: 10rpx;
}

.message.received {
  align-self: flex-start;
  background: #ffffff;
  color: #1c1c1e;
  border-bottom-left-radius: 8rpx;
  border: 1rpx solid #eceff3;
}

.message.sent {
  align-self: flex-end;
  margin-left: auto;
  background: #1c1c1e;
  color: #ffffff;
  border-bottom-right-radius: 8rpx;
}

.message.system {
  align-self: center;
  margin-left: auto;
  margin-right: auto;
  max-width: 92%;
  background: #fff7ed;
  color: #9a3412;
  border: 1rpx solid #fed7aa;
  border-radius: 12rpx;
}

.message-text {
  word-break: break-word;
}

.timestamp {
  display: block;
  font-size: 18rpx;
  color: #8e8e93;
  margin-top: 6rpx;
}

.message.sent .timestamp {
  color: rgba(255, 255, 255, 0.68);
  text-align: right;
}

.message.system .timestamp {
  color: #c2410c;
  text-align: right;
}

.input-bar-container {
  padding: 12rpx 24rpx calc(22rpx + env(safe-area-inset-bottom));
  background: #e3e3e5;
}

.input-wrapper {
  background: #ffffff;
  border-radius: 999rpx;
  padding: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.05);
}

.chat-input {
  flex: 1;
  border: none;
  background: transparent;
  font-size: 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 12rpx;
}

.send-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 50% !important;
  background: #1c1c1e !important;
  color: #ffffff !important;
  padding: 0 !important;
  min-width: 56rpx;
}

.send-btn::after {
  border: 0;
}

.empty {
  color: #8e8e93;
  font-size: 22rpx;
  text-align: center;
  margin-top: 12rpx;
}

.missing-page {
  padding: 48rpx 24rpx;
  color: #8e8e93;
  text-align: center;
}
