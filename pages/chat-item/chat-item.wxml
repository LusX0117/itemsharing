<navigation-bar title="物品详情" color="black" background="#e3e3e5"></navigation-bar>

<view wx:if="{{loading}}" class="missing-page">物品详情加载中...</view>

<view wx:elif="{{session}}" class="detail-page">
  <scroll-view class="content-scroll" scroll-y enhanced enable-flex show-scrollbar="false">
    <view class="content-wrap">
      <view class="item-title">{{session.itemTitle}}</view>

      <view class="item-desc">{{session.itemDescription}}</view>

      <view class="image-wrap">
        <view wx:if="{{!session.displayImages || session.displayImages.length === 0}}" class="image-empty">
          暂无物品图片
        </view>
        <image
          wx:for="{{session.displayImages}}"
          wx:key="*this"
          class="item-image"
          src="{{item}}"
          mode="widthFix"
          data-url="{{item}}"
          bindtap="previewItemImage"
        ></image>
      </view>
    </view>
  </scroll-view>

  <view class="action-fab-wrap">
    <button class="action-fab" bindtap="goChatPage">{{session.chatEntryText}}</button>
  </view>
</view>

<view wx:else class="missing-page">未找到物品详情</view>
