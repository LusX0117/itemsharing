<navigation-bar title="物品详情" color="black" background="#e3e3e5"></navigation-bar>

<view wx:if="{{loading}}" class="missing-page">物品详情加载中...</view>

<view wx:elif="{{session}}" class="detail-page">
  <scroll-view class="content-scroll" scroll-y enhanced enable-flex show-scrollbar="false">
    <view class="content-wrap">
      <view class="item-card">
        <view class="item-thumb">{{session.itemTitleShort}}</view>
        <view class="item-main">
          <view class="item-title">{{session.itemTitle}}</view>
          <view class="status-badge {{session.statusBadgeClass}}">{{session.statusBadgeText}}</view>
          <view class="item-meta">出借者：{{session.lenderName}}</view>
          <view class="item-meta">借用者：{{session.borrowerName}}</view>
        </view>
      </view>

      <view class="stepper-container">
        <view class="stepper-line"></view>
        <view wx:for="{{session.stageSteps}}" wx:key="label" class="step {{item.current ? 'active' : ''}} {{item.done ? 'completed' : ''}}">
          <view class="step-dot"></view>
          <view class="step-label">{{item.label}}</view>
        </view>
      </view>

      <view class="card action-panel">
        <view wx:if="{{session.pendingBorrowApproval}}" class="status-tip">当前等待出借者同意后才会进入借用中</view>
        <view wx:if="{{session.status === '待确认归还'}}" class="status-tip">当前为归还确认阶段，需出借者确认后完成</view>

        <view wx:if="{{session.canApproveBorrow || session.canRejectBorrow}}" class="action-row">
          <button class="mini-btn solid" size="mini" bindtap="approveBorrow">同意借用</button>
          <button class="mini-btn warn" size="mini" bindtap="rejectBorrow">拒绝借用</button>
        </view>
        <view wx:if="{{session.canRequestReturn}}" class="action-row">
          <button class="mini-btn blue" size="mini" bindtap="requestReturn">发起归还确认</button>
        </view>
        <view wx:if="{{session.canCancelBorrow}}" class="action-row">
          <button class="mini-btn orange" size="mini" bindtap="cancelBorrow">取消借用</button>
        </view>
        <view wx:if="{{session.canConfirmReturn || session.canRejectReturn}}" class="action-row">
          <button class="mini-btn solid" size="mini" bindtap="confirmReturn">确认归还</button>
          <button class="mini-btn warn" size="mini" bindtap="rejectReturn">退回确认</button>
        </view>
      </view>

      <view class="card media-card">
        <view class="media-title">借前/归还后照片</view>
        <view class="media-actions">
          <button class="mini-btn ghost" size="mini" bindtap="addBeforePhoto">借前照片</button>
          <button class="mini-btn ghost" size="mini" bindtap="addAfterPhoto">归还后照片</button>
        </view>

        <view class="media-group-title">借前照片</view>
        <view class="photo-grid">
          <image
            wx:for="{{session.beforePhotos}}"
            wx:key="*this"
            class="photo"
            src="{{item}}"
            mode="aspectFill"
            data-url="{{item}}"
            bindtap="previewPhoto"
          ></image>
        </view>

        <view class="media-group-title">归还后照片</view>
        <view class="photo-grid">
          <image
            wx:for="{{session.afterPhotos}}"
            wx:key="*this"
            class="photo"
            src="{{item}}"
            mode="aspectFill"
            data-url="{{item}}"
            bindtap="previewPhoto"
          ></image>
        </view>

        <view wx:if="{{compareRows.length === 0}}" class="empty">上传借前和归还后照片后可在此对比</view>

        <view wx:for="{{compareRows}}" wx:key="index" class="compare-row">
          <view class="compare-col">
            <view class="compare-label">借前 {{item.index + 1}}</view>
            <image
              wx:if="{{item.before}}"
              class="compare-photo"
              src="{{item.before}}"
              mode="aspectFill"
              data-url="{{item.before}}"
              bindtap="previewPhoto"
            ></image>
            <view wx:else class="compare-empty">暂无</view>
          </view>
          <view class="compare-col">
            <view class="compare-label">归还后 {{item.index + 1}}</view>
            <image
              wx:if="{{item.after}}"
              class="compare-photo"
              src="{{item.after}}"
              mode="aspectFill"
              data-url="{{item.after}}"
              bindtap="previewPhoto"
            ></image>
            <view wx:else class="compare-empty">暂无</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-action">
    <button class="back-chat-btn" bindtap="goBack">返回聊天页</button>
  </view>
</view>

<view wx:else class="missing-page">未找到借用会话</view>
