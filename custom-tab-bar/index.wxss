.liquid-shell {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  border-radius: 999rpx;
  padding: 8rpx;
  background: rgba(246, 248, 251, 0.34);
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  box-shadow: 0 14rpx 36rpx rgba(15, 23, 42, 0.18), inset 0 1rpx 0 rgba(255, 255, 255, 0.88);
  overflow: hidden;
  z-index: 999;
  -webkit-backdrop-filter: blur(28rpx) saturate(145%);
  backdrop-filter: blur(28rpx) saturate(145%);
}

.liquid-highlight {
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 6rpx;
  height: 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.32), rgba(255, 255, 255, 0));
  pointer-events: none;
}

.tab-list {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tab-item {
  position: relative;
  flex: 1;
  height: 82rpx;
  margin: 0 4rpx;
  border-radius: 999rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: rgba(17, 24, 39, 0.75);
  transition: all 220ms ease;
}

.tab-item.active {
  background: rgba(255, 255, 255, 0.82);
  color: #0f172a;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.95), 0 6rpx 18rpx rgba(15, 23, 42, 0.08);
}

.tab-text {
  font-size: 24rpx;
  line-height: 1;
  letter-spacing: 0.4rpx;
  font-weight: 600;
}
