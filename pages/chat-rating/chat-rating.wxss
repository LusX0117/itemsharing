page {
  height: 100vh;
  background: #e3e3e5;
  color: #1c1c1e;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.rating-page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.content-scroll {
  flex: 1;
  min-height: 0;
}

.content-wrap {
  padding: 22rpx 24rpx 180rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 0 8rpx;
}

.header-title-wrap {
  display: flex;
  flex-direction: column;
  line-height: 1.05;
}

.header-title {
  font-size: 54rpx;
  font-weight: 600;
  letter-spacing: -1rpx;
}

.close-btn {
  color: #8e8e93;
  font-size: 40rpx;
  padding: 6rpx 10rpx;
}

.item-summary-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
}

.item-thumb {
  width: 110rpx;
  height: 110rpx;
  border-radius: 12rpx;
  background: #e3e3e5;
  color: #6b7280;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  line-height: 1.2;
  padding: 6rpx;
  box-sizing: border-box;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  word-break: break-all;
}

.status-badge {
  margin-top: 6rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-badge.returned {
  color: #34c759;
}

.status-badge.pending {
  color: #f59e0b;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

.review-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 18rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.04);
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.input-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #8e8e93;
  padding-left: 6rpx;
}

.input-label.center {
  text-align: center;
  padding-left: 0;
}

.rating-container {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  padding: 6rpx 0;
}

.star-btn {
  font-size: 52rpx;
  line-height: 1;
  color: #d1d1d6;
  padding: 2rpx 4rpx;
}

.star-btn.active {
  color: #ffcc00;
}

.readonly-tip {
  text-align: center;
  font-size: 20rpx;
  color: #8e8e93;
}

.form-textarea {
  width: 100%;
  min-height: 220rpx;
  background: #e3e3e5;
  border: 0;
  border-radius: 12rpx;
  padding: 18rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  line-height: 1.5;
  color: #1c1c1e;
}

.credit-tip {
  font-size: 20rpx;
  color: #8e8e93;
  padding-left: 6rpx;
}

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 12rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #e3e3e5 72%, rgba(227, 227, 229, 0));
  z-index: 10;
}

.btn-submit {
  width: 100%;
  background: #1c1c1e !important;
  color: #ffffff !important;
  border-radius: 999rpx !important;
  padding: 0 28rpx !important;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 14rpx 30rpx rgba(0, 0, 0, 0.14);
}

.btn-submit.disabled {
  background: #94a3b8 !important;
  box-shadow: none;
}

.btn-submit::after {
  border: 0;
}

.missing-page {
  padding: 48rpx 24rpx;
  color: #8e8e93;
  text-align: center;
}
