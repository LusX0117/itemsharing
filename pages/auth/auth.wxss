page {
  height: 100vh;
  background: #e3e3e5;
  color: #1c1c1e;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.scrollarea {
  flex: 1;
  min-height: 0;
}

.page-wrap {
  padding: 24rpx 24rpx calc(280rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 0 8rpx;
}

.header-title {
  white-space: pre-line;
  font-size: 54rpx;
  line-height: 1.08;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.close-btn {
  font-size: 44rpx;
  color: #8e8e93;
  line-height: 1;
  padding: 8rpx;
}

.auth-tabs {
  display: flex;
  gap: 34rpx;
  margin: 16rpx 8rpx 0;
}

.tab-item {
  font-size: 32rpx;
  font-weight: 600;
  color: #8e8e93;
  padding-bottom: 6rpx;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #1c1c1e;
  border-bottom-color: #1c1c1e;
}

.form-card {
  margin-top: 22rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.input-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #8e8e93;
  padding-left: 4rpx;
}

.forgot-link {
  font-size: 22rpx;
  color: #8e8e93;
}

.form-input {
  width: 100%;
  background: #edf0f4;
  border-radius: 16rpx;
  min-height: 92rpx;
  padding: 0 22rpx;
  line-height: 92rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.bottom-action {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  padding: 0 24rpx;
  z-index: 20;
}

.btn-submit {
  width: 100%;
  height: 94rpx;
  line-height: 94rpx;
  border-radius: 999rpx !important;
  background: #1c1c1e !important;
  color: #ffffff !important;
  font-size: 30rpx !important;
  font-weight: 600;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.15);
}

.btn-submit::after {
  border: 0;
}
